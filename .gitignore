# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Cached market data (regenerated on run; not committed)
data/cache/

# The immutable signal log is YOUR research record, not the repo's. Ignored by
# default so scans don't dirty the tree; remove this line to version your track
# record. Back it up either way — unlike the cache, it is not regenerable.
data/signals/

# Batch reports + cron logs (generated by the daily batch job)
data/reports/

# Trade log (paper + live orders) — your execution record, like the signal log.
# Not regenerable; back it up. Never committed by default.
data/trades/

# Dhan instrument master (symbol -> securityId) for live orders; user-supplied.
data/dhan_instruments.json

# Env and secrets (.env.local is loaded by config.py too — never commit it)
.env
.env.local

# Tooling
.pytest_cache/
.ruff_cache/
.coverage
.DS_Store

# graphify: SHARE the useful outputs (graph.json/graph.html, GRAPH_REPORT.md,
# manifest.json) so collaborators reuse the context. But keep out the parts that
# leak local machine paths (/Users/...) or just churn every run.
graphify-out/cache/
graphify-out/.graphify_*
graphify-out/cost.json

# Derived from the (ignored) signal log by `calibrate`; user-specific
data/calibration.json

# Per-machine source-health diagnostics, rebuilt by `ingest`. Safe to delete.
data/health.json

# Lock directory held by scripts/daily.sh while a run is in flight
data/.daily.lock/
