# Alpha Engine runs with NO keys on the default paths: crypto (CoinGecko) and
# US equities (Yahoo) both work on a fresh clone. Keys below only ADD layers.
#
# Discovery: `.env.local` / `.env` are looked up in the current directory, the
# project root, and parent directories (first match per name wins). Variables
# already set in your shell always take priority over anything in these files.

# US macro context blended into equity signals (free key from
# https://fred.stlouisfed.org). Without it, equity scans are trend-only.
FRED_API_KEY=

# Optional Indian broker creds. Breeze is the easiest live path for F&O chain
# fetches; leave these blank if you only use fixtures / cached chains.
BREEZE_API_KEY=
BREEZE_API_SECRET=
BREEZE_CLIENT_ID=
BREEZE_USER_ID=
BREEZE_SESSION_TOKEN=

# Angel One (SmartAPI) is the alternate live F&O path:
#   fetch-chain NIFTY --expiry 2026-07-30 --broker angelone
# Get the access token (a JWT) by logging in via SmartAPI, then set it here.
ANGEL_ONE_API_KEY=
ANGEL_ONE_API_SECRET=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_ACCESS_TOKEN=

# Dhan is another live F&O path:
#   fetch-chain NIFTY --expiry 2026-07-30 --broker dhan
# Get credentials from https://dhan.co -> My Account -> API
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Optional CoinGecko Pro key: raises crypto rate limits, never required.
# Keyless CoinGecko + the keyless Binance fallback cover the default path.
COINGECKO_API_KEY=

# Optional OANDA credentials for forex candles (free practice account at
# https://www.oanda.com). OANDA_ENV can be "practice" (default) or "live".
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# Optional LLM narrator. With none set, a deterministic template writes the thesis.
# Supports any OpenAI-compatible API (OpenAI, Anthropic via proxy, local models).
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_API_BASE=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# EXECUTION / LIVE TRADING — all off by default. Read GETTING_STARTED.md Part 6.
# ---------------------------------------------------------------------------

# The master switch. Orders are simulated ("paper") unless this is set truthy.
# Leave blank to stay safe. Set to 1 ONLY when you intend to trade real money.
LIVE_TRADING=

# Hard safety caps — an order past either is rejected BEFORE it reaches a broker,
# even in live mode. Defaults (100 units / 500000 notional) apply if left blank.
MAX_ORDER_QTY=
MAX_ORDER_NOTIONAL=

# Shared password for the inbound trade webhook. The webhook server refuses to
# start without this. Use a long random string.
WEBHOOK_SECRET=
